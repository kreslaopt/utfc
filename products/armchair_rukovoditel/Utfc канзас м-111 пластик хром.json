  "technical_requirements": [
    [
      "Кресло должно соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- материал облицовки спинки и сиденья кресла: искусственная кожа<br>- цвет материала - по каталогу"
      ],
      "components": [
        "спинки, сиденья, подлокотников, механизма, газ-лифта, пятилучья и 5-ти роликов",
        "<strong>Спинка</strong> состоит из основания, вкладыша пенополиуретанового и обивочного материала",
        "<strong>Сиденье</strong> состоит из основания, вкладыша пенополиуретанового и обивочного элемента",
        "<strong>Облицовка спинки и сиденья</strong>: искусственная кожа",
        "<strong>Подлокотники</strong> - пластиковые с мягкими накладками и вставками с имитацией под хром. Механизм позволяет регулировать высоту сиденья относительно пола, отклонение спинки на 165 градусов и обеспечивает фиксацию наклона в любом положении",
        "<strong>Газ-лифт</strong> хромированный с высотой подъема 60 мм ± 10 мм позволяет плавно регулировать высоту сиденья относительно пола",
        "<strong>Пятилучье</strong> хромированное d=700 мм с 5-тью роликами обеспечивает устойчивость и позволяет креслу легко поворачиваться и перемещаться по любому стандартному покрытию пола",
        "<strong>Ролики</strong> черные с полиуретановым покрытием d=60 мм имеют узкий шток"
      ]
    }
  ],
