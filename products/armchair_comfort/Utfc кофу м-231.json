  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- материал облицовки спинки:<br>сетка<br>\n- материал облицовки сиденья:<br>ткань<br>\n- цвет материала - по каталогу"
      ],
      "components": [
        "спинки, сиденья, подлокотников, механизма качания, газ-лифта, пятилучья и 5-ти роликов",
        "<strong>Спинка</strong> состоит из пластикового каркаса с поясничной поддержкой и обивочного элемента. Поясничная поддержка регулируется по глубине и высоте. Облицовка спинки: сетка",
        "<strong>Сиденье</strong> состоит из основания, пенополиуретана и обивочного элемента. Облицовка сиденья: ткань",
        "<strong>Подлокотники</strong> - пластиковые, регулируются по высоте",
        "<strong>Механизм качания</strong> «Топ-ган» позволяет регулировать высоту сиденья, регулировку силы отклонения спинки под вес пользователя в режиме качания и фиксацию в вертикальном положении",
        "<strong>Газ-лифт</strong> с высотой подъема 100 мм ± 10 мм позволяет плавно регулировать высоту сиденья относительно пола",
        "<strong>Пятилучье</strong> пластиковое d=640 мм с узкими лучами с 5-тью роликами обеспечивает устойчивость и позволяет креслу легко поворачиваться и перемещаться по любому стандартному покрытию пола",
        "<strong>Ролики</strong> пластиковые d=50 мм имеют открытый чехол"
      ]
    }
  ],
