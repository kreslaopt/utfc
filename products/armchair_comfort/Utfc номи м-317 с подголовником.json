  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- материал облицовки спинки:<br>сетка<br>\n- материал облицовки сиденья: ткань<br>\n- цвет материала - по каталогу"
      ],
      "components": [
        "подголовника, спинки, сиденья, подлокотников, механизма качания, газ-лифта, пятилучья и 5-ти роликов",
        "<strong>Подголовник</strong> состоит из пластикового каркаса, кронштейна и обивочного элемента. Облицовка подголовника: сетка",
        "<strong>Спинка</strong> состоит из пластикового каркаса и обивочного элемента. Облицовка спинки: сетка",
        "<strong>Сиденье</strong> из основания, пенополиуретана и обивочного элемента. Облицовка сиденья: ткань",
        "<strong>Подлокотники</strong> - пластиковые, крепятся к основанию сиденья с помощью винтов",
        "<strong>Механизм качания</strong> «Топ-ган» позволяет регулировать высоту сиденья, регулировку силы отклонения спинки под вес пользователя в режиме качания и фиксацию в вертикальном положении",
        "<strong>Газ-лифт</strong> черный с высотой подъема 100 мм ± 10 мм позволяет плавно регулировать высоту сиденья относительно пола",
        "<strong>Пятилучье</strong> пластиковое d=680 мм с узкими лучами с 5-тью роликами обеспечивает устойчивость и позволяет креслу легко поворачиваться и перемещаться по любому стандартному покрытию пола",
        "<strong>Ролики</strong> с полиуретановым покрытием d=55 мм имеют узкий шток"
      ]
    }
  ],
