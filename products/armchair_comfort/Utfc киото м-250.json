  "technical_requirements": [
    [
      "Кресло должно соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- материал облицовки спинки и подголовника:<br>сетка<br>\n- материал облицовки сиденья:<br>ткань<br>\n- цвет материала и пластика - по каталогу"
      ],
      "components": [
        "подголовника, спинки, сиденья, подлокотников, механизма качания, газ-лифта, пятилучья и 5-ти роликов",
        "<strong>Подголовник</strong> состоит из пластикового каркаса и обивочного элемента, регулируется по высоте и углу наклона. Облицовка подголовника: сетка",
        "<strong>Спинка</strong> состоит из пластикового каркаса и обивочного элемента. Облицовка спинки: сетка",
        "<strong>Сиденье</strong> состоит из пластикового каркаса, пенополиуретана и обивочного элемента. Облицовка сиденья: ткань",
        "<strong>Подлокотники</strong> пластиковые, регулируются по высоте. В черном каркасе накладки подлокотника регулируются вперед-назад",
        "<strong>Механизм качания</strong> позволяет регулировать высоту и глубину сиденья, регулировку силы отклонения спинки под вес пользователя в режиме качания и фиксацию в трех положениях",
        "<strong>Газ-лифт</strong> с высотой подъема 100 мм ± 10 мм позволяет плавно регулировать высоту сиденья относительно пола",
        "<strong>Пятилучье</strong> пластиковое d=680 мм с узкими лучами с 5-тью роликами обеспечивает устойчивость и позволяет креслу легко поворачиваться и перемещаться по любому стандартному покрытию пола",
        "<strong>Ролики</strong> с полиуретановым покрытием d=60 мм имеют узкий шток"
      ]
    }
  ],
