  "technical_requirements": [
    [
      "Кресло должно соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- материал облицовки спинки:<br>ткань-сетка (TW)<br>\n- материал облицовки сиденья:<br>ткань-сетка (E)<br>\n- цвет материала и пластика - по каталогу"
      ],
      "components": [
        "металлических полозьев, спинки, сиденья, подлокотников",
        "<strong>Полозья</strong> «Нео» сварные металлические с защитно-декоративным покрытием",
        "<strong>Каркас</strong> и перемычки полозьев изготовлен из стальной трубы круглого сечения Ф25х2 мм. Покрытие полозьев: термореактивная порошковая краска, цвет - черный или хромовое блестящее. На торцевые поверхности каркаса полозьев устанавливаются заглушки (2 шт.). На опорную поверхность каркаса полозьев устанавливаются опоры (4 шт.)",
        "<strong>Спинка</strong> состоит из пластикового каркаса с опорой для спины и обивочного элемента",
        "<strong>Материал</strong> облицовки спинки: ткань-сетка (TW)",
        "<strong>Сиденье</strong> состоит из основания фанерного, вкладыша пенополиуретанового (жесткость - 40, плотность 20 кг/м<sup>3</sup>) и обивочного элемента",
        "<strong>Материал</strong> облицовка сиденья: ткань-сетка (Е)",
        "<strong>Подлокотники</strong> - пластиковые, крепятся к каркасу спинки и к основанию сиденья с помощью винтов"
      ]
    }
  ],
