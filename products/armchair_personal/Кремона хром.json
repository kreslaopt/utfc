  "technical_requirements": [
    [
      "Кресло должно соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- материал облицовки спинки и сиденья: велюр (Velutto)<br>\n- цвет материала и пластика - по каталогу"
      ],
      "components": [
        "спинки, сиденья, пиастры, газ-лифта, пятилучья и 5-ти роликов",
        "<strong>Спинка</strong> состоит из основания фанерного, вкладыша пенополиуретанового (жесткость - 40, плотность 22 кг/м<sup>3</sup>) и обивочного элемента. Крепится к сиденью с помощью саморезов",
        "<strong>Сиденье</strong> состоит из основания фанерного, вкладыша пенополиуретанового (жесткость - 60, плотность 40 кг/м<sup>3</sup>) и обивочного элемента",
        "<strong>Материал</strong> облицовки спинки и сиденья: велюр (Velutto)",
        "<strong>Пиастра</strong> крепится к основанию сиденья с помощью 4-х винтов, снабжена рычагом регулировки газ-лифта",
        "<strong>Газ-лифт</strong> с высотой подъема 140 мм ± 10 мм позволяет плавно регулировать высоту сиденья относительно пола",
        "<strong>Пятилучье</strong> «Альфа» - хромированное d=640 мм с 5-тью роликами обеспечивает устойчивость и позволяет креслу легко поворачиваться и перемещаться по любому стандартному покрытию пола",
        "<strong>Ролики</strong> с полиуретановым покрытием d=50 мм имеют открытый пластиковый чехол"
      ]
    }
  ],
