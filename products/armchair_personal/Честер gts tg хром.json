    "construction_and_materials": [
        {
            "upholstery_materials": [
                "-  материал облицовки спинки-сиденья и накладок подлокотников soft кресла:<br>ткань (Moderno), кожзаменитель (Z), экокожа (S,R)<br>- цвет материала - по каталогу"
            ],
            "components": [
                "спинки-сиденья, подлокотников, пиастры, газ-лифта, пятилучья и 5-ти роликов",
                "<strong>Спинка-сиденье</strong> состоит из фанерного основания, мягкого элемента (пенополиуретан, жесткость - 40, плотность - 20 кг/м<sup>3</sup>) и облицовки",
                "<strong>Материал</strong> облицовки спинки-сиденья: ткань (Moderno), кожзаменитель (Z), экокожа (S,R)",
                "<strong>Подлокотники</strong> состоят из каркаса и накладок. Каркас подлокотников металлический с защитно-декоративным покрытием, изготовлен из стальной трубы круглого сечения Ф16х1,2 мм. Покрытие каркаса: хромовое блестящее. Накладки подлокотников - пластиковые, крепятся к каркасу с помощью саморезов",
                "<strong>Пиастра</strong> крепится к основанию сиденья с помощью 4-х винтов М6,снабжена рычагом регулировки газ-лифта. По желанию заказчика пиастра может быть заменена на механизм качания «Топ-ган»",
                "<strong>Газ-лифт</strong> с высотой подъема 120 мм ± 10 мм позволяет плавно регулировать высоту сиденья относительно пола, подпружинивает сиденье и демпфирует нагрузку на позвоночник в момент посадки",
                "<strong>Пятилучье</strong> «Испания» - хромированное d=640 мм с 5-тью роликами обеспечивает устойчивость и позволяет креслу легко поворачиваться и перемещаться по любому стандартному покрытию пола",
                "<strong>Ролики</strong> черные d=50 мм имеют имеют открытый пластиковый чехол. По желанию заказчика пластиковые ролики могут быть заменены на ролики с полиуретановым покрытием (Ср) или глайдеры (G)"
            ]
        }
