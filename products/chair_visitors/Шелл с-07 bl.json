  "technical_requirements": [
    [
      "Стул должен соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "- тип покрытия каркаса стула: CH, BL, GR где<br>\nCH - хромовое блестящее,<br>\nBL - окрашенный, цвет черный<br>\nGR - окрашенный, цвет серый<br>\n- цвет пластикового каркаса-ракушки - по каталогу<br>- цвет материала - по каталогу"
      ],
      "components": [
        "металлического каркаса, пластикового каркаса-ракушки, пластиковых заглушек и крепежных элементов. Нерегулируемый",
        "<strong>Каркас</strong> стула сварной металлический с защитно-декоративным покрытием. Ножки изготовлены из стальной трубы круглого сечения Ф18х1,5 мм",
        "<strong>Покрытие каркаса</strong>: термореактивная порошковая краска черного или серого цвета, хромовое блестящее",
        "На опорную поверхность ножек каркаса устанавливаются заглушки",
        "<strong>Каркас-ракушка</strong> крепится к металлическому каркасу с помощью 4-х винтов",
        "По желанию заказчика на каркас можно приобрести чехол. Материал чехла: ткань (Moderno, QH)"
      ]
    }
  ],
