  "destiny": [
    "работы и кратковременного отдыха сидя<br>Устанавливается в жилых и административных помещениях<br>Изготавливается с мягким элементом спинки-сиденья"
  ],
  "technical_requirements": [
    [
      "Стул должен соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "-  тип покрытия каркаса стула:<br>CH, BL, где<br>\nCH - хромовое блестящее<br>\nBL - окрашенный, цвет черный<br>\n- материал облицовки спинки-сиденья стула:<br>ткань (Moderno), экокожа (S,R), велюр (Velutto)<br>\n- цвет материала - по каталогу"
      ],
      "components": [
        "металлического каркаса, спинки-сиденья, накладок подлокотников, пластиковых опор и крепежных элементов. Нерегулируемый",
        "<strong>Каркас</strong> стула сварной металлический с защитно-декоративным покрытием",
        "<strong>Каркас</strong> и перекладины изготовлены из стальной трубы круглого сечения Ф16х2 мм, связи - из стального листа толщиной 3 мм",
        "<strong>Покрытие каркаса</strong>: хромовое блестящее. На опорную поверхность ножек каркаса устанавливаются опоры (4 шт.)",
        "<strong>Спинка-сиденье</strong> состоит из фанерного основания, мягкого элемента (пенополиуретан, жесткость - 40, плотность - 25 кг/м<sup>3</sup>) и облицовки. Крепится к каркасу с помощью 4-х винтов и 2-х саморезов",
        "<strong>Материал</strong> облицовки спинки-сиденья: ткань (Moderno), экокожа (S,R), велюр (Velutto)",
        "<strong>Накладки подлокотников</strong> пластиковые, каждая накладка крепится к каркасу на 2 самореза"
      ]
    }
  ],
