  "destiny": [
    "работы и кратковременного отдыха сидя<br>Устанавливается в жилых и административных помещениях<br>Изготавливается с мягким элементом спинки-сиденья"
  ],
  "technical_requirements": [
    [
      "Стул должен соответствовать требованиям:",
      "ГОСТ 19917-2014 «Мебель для сидения и лежания. Общие технические условия»",
      "ГОСТ 26800.3-86 «Мебель для административных помещений. Функциональные размеры»",
      "настоящего технического описания",
      "комплекта конструкторской документации",
      "образцу-эталону, утвержденному в установленном порядке производителем"
    ]
  ],
  "construction_and_materials": [
    {
      "upholstery_materials": [
        "-  тип покрытия каркаса стула:<br>CH, BL где<br>CH - хромовое блестящее<br>\nBL - окрашенный, цвет черный<br>\n- материал облицовки спинки-сиденья и накладок подлокотников стула:<br>\nкожзаменитель (Z), экокожа (S,R)<br>\n- цвет материала - по каталогу"
      ],
      "components": [
        "металлического каркаса, спинки-сиденья, накладок подлокотников, пластиковых опор и крепежных элементов. Нерегулируемый",
        "<strong>Каркас</strong> стула сварной металлический с защитно-декоративным покрытием",
        "<strong>Каркас</strong> изготовлен из стальной трубы округлого сечения Ф25х2 мм, перекладины - из трубы круглого сечения Ф20х1,2 мм",
        "<strong>Покрытие каркаса</strong>: термореактивная порошковая краска черного цвета или хромовое блестящее. На опорную поверхность каркаса устанавливаются опоры (4 шт.)",
        "<strong>Спинка-сиденье</strong> состоит из фанерного основания, мягкого элемента (пенополиуретан, жесткость - 40, плотность - 22 кг/м<sup>3</sup>) и облицовки. Крепится к каркасу с помощью 2-х винтов и двух саморезов",
        "<strong>Накладки подлокотников</strong> состоят из фанерного основания, мягкого элемента (пенополиуретан, жесткость - 25, плотность - 16 кг/м<sup>3</sup>) и облицовки. Крепятся к каркасу с помощью 4-х винтов",
        "<strong>Материал</strong> облицовки спинки-сиденья и накладок подлокотников: кожзаменитель (Z), экокожа (S,R)",
        "<strong>Столик</strong> поворотный устанавливается на кронштейн каркаса и крепится с помощью винта и гайки М5"
      ]
    }
  ],
